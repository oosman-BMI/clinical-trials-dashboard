# ============================================================
# Twine Pulse — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Make a copy of this file and name it exactly:  .env
#   2. Fill in each value below (remove the placeholder text)
#   3. NEVER share or commit the .env file — it contains secrets
# ============================================================

# --- Anthropic (Claude AI) ---
# Get this from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Databricks ---
# Your technical team will provide all three of these values
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=your-personal-access-token

# --- Databricks Catalog & Schema ---
# This is the location of your tables inside Databricks
# Default: twinepulse.main  (ask your tech team to confirm)
DATABRICKS_CATALOG=twinepulse
DATABRICKS_SCHEMA=main

# --- App Settings ---
# Environment: development or production
APP_ENV=development

# Allowed origins for the frontend (comma-separated URLs)
# In development this can be * (open). In production set to your real URL.
CORS_ORIGINS=*
